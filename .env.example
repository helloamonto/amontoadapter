# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── TikTok App Credentials ──────────────────────────────────────────────────
# Obtained from TikTok Developer Portal (https://developers.tiktok.com/)
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# TikTok Business Account ID (the inbox owner)
TIKTOK_BUSINESS_ID=your_tiktok_business_id

# Webhook verification token set in TikTok Developer Portal
TIKTOK_WEBHOOK_VERIFY_TOKEN=your_random_secret_string

# ─── Genesys Cloud Credentials ────────────────────────────────────────────────
# OAuth Client Credentials grant — create in Genesys Cloud Admin > OAuth
GENESYS_CLIENT_ID=your_genesys_oauth_client_id
GENESYS_CLIENT_SECRET=your_genesys_oauth_client_secret

# Genesys Cloud region base URL, e.g. https://api.mypurecloud.com (US East)
# Other regions: https://api.mypurecloud.ie / https://api.mypurecloud.de / etc.
GENESYS_BASE_URL=https://api.mypurecloud.com

# Open Messaging Integration ID — from Admin > Message > Platforms > (your integration)
GENESYS_INTEGRATION_ID=your_genesys_open_messaging_integration_id

# Secret token set in Genesys Open Messaging integration (used to verify outbound webhooks)
GENESYS_WEBHOOK_SECRET=your_genesys_outbound_webhook_secret

# ─── Comment Polling (fallback for TikTok comment webhooks) ───────────────────
# Cron expression for polling TikTok comments (default: every 2 minutes)
COMMENT_POLL_CRON=*/2 * * * *
